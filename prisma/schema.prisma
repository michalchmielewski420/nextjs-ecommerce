generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" // 🚀 Baza zapisze się jako zwykły plik dev.db w folderze prisma!
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  price       Int      
  description String
  image_url   String
  category    String
  createdAt   DateTime @default(now())
  likes       Int      @default(0) 
}