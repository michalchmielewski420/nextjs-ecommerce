generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" // 🚀 Baza zapisze się jako zwykły plik dev.db w folderze prisma!
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  price       Int      // cena w groszach
  description String
  image_url   String
  category    String
  likes       Int      @default(0)
  stock       Int      @default(10) // 🚀 NOWE POLE: domyślnie 10 sztuk na magazynie
  createdAt   DateTime @default(now())
}

model Order {
  id        String   @id @default(cuid())
  items     String   // Tutaj zapiszemy listę produktów jako tekst JSON (nazwy, ilości)
  total     Int      // Łączna kwota zamówienia w groszach
  status    String   @default("Opłacone")
  createdAt DateTime @default(now())
}