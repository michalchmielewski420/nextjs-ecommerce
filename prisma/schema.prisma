generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  price       Float    
  description String
  image_url   String
  category    String
  createdAt   DateTime @default(now())
}